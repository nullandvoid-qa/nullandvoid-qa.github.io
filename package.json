{
  "name": "testersguild.github.io",
  "version": "1.0.0",
  "description": "Null and Void QA Course - Main Website",
  "private": true,
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:verbose": "jest --coverage --verbose",
    "test:e2e": "npx playwright test",
    "validate:tracks": "node scripts/validate-tracks.js",
    "lint:js": "eslint js/ --ext .js",
    "lint:css": "stylelint css/**/*.css",
    "lint:html": "htmlhint *.html",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "format": "prettier --write \"**/*.{js,json,css,html,md}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "eslint": "^8.57.0",
    "eslint-plugin-jest": "^27.9.0",
    "htmlhint": "^1.1.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.2.5",
    "stylelint": "^16.3.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "playwright": "^1.61.1"
  }
}
