{
  "env": {
    "browser": true,
    "es2021": true,
    "jest": true
  },
  "globals": {
    "global": "readonly",
    "module": "readonly",
    "window": "readonly",
    "document": "readonly",
    "localStorage": "readonly",
    "sessionStorage": "readonly",
    "Blob": "readonly",
    "URL": "readonly",
    "confirm": "readonly",
    "setTimeout": "readonly",
    "clearTimeout": "readonly",
    "escapeHtml": "readonly",
    "getCurrentLangKey": "readonly",
    "loadJson": "readonly",
    "saveJson": "readonly",
    "validateProgressData": "readonly",
    "validateBookmarksData": "readonly",
    "validateQuizzesPassedData": "readonly",
    "showToast": "readonly",
    "t": "readonly",
    "getStorage": "readonly",
    "persistProgress": "readonly",
    "getStoredProgress": "readonly",
    "loadProgress": "readonly",
    "saveProgress": "readonly",
    "saveLastLesson": "readonly",
    "exportProgressToFile": "readonly",
    "importProgressFromFile": "readonly",
    "renderHome": "readonly",
    "renderTracksPage": "readonly",
    "renderRoadmap": "readonly",
    "renderGlossary": "readonly",
    "renderLabs": "readonly",
    "renderTrackDetail": "readonly",
    "renderLesson": "readonly",
    "renderQuiz": "readonly",
    "renderDashboard": "readonly",
    "renderChecklist": "readonly",
    "renderLessonQuiz": "readonly",
    "renderTrackCard": "readonly",
    "renderContinueBanner": "readonly",
    "refreshCurrentView": "readonly",
    "navigate": "readonly"
  },
  "extends": [
    "eslint:recommended",
    "plugin:jest/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["jest"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "prefer-const": "error",
    "no-var": "error"
  },
  "overrides": [
    {
      "files": ["js/i18n.js"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}